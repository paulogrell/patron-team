{
  "name": "team-queue-indexeddb",
  "version": "1.2.0",
  "description": "Web app offline-first para gerenciar fila de jogadores e formar times usando IndexedDB",
  "private": true,
  "type": "module",
  "homepage": "https://paulogrell.github.io/patron-team/",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bdd": "cucumber-js --config cucumber.mjs",
    "test:bdd:smoke": "cucumber-js --config cucumber.mjs --tags \"@smoke and not @skip\"",
    "test:bdd:regression": "cucumber-js --config cucumber.mjs --tags \"@regression and not @skip\"",
    "test:e2e:ui": "playwright test --ui",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.1",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^4.2.1",
    "fake-indexeddb": "^5.0.2",
    "gh-pages": "^6.1.1",
    "jsdom": "^29.0.1",
    "vite": "^5.4.0",
    "vitest": "^1.6.0",
    "wait-on": "^9.0.5"
  }
}
